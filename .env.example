# Copy to .env.local for local dev, or set these in Vercel → Project → Settings →
# Environment Variables. With NO key set, the app runs in deterministic MOCK mode.

# Required for real tool-calling decisions:
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Optional — live traces of every tool call (free tier at cloud.langfuse.com):
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASEURL=https://cloud.langfuse.com
